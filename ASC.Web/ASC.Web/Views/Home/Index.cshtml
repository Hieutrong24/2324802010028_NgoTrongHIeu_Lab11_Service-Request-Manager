@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

<style>
    .home-banner {
        width: 100%;
        min-height: 430px;
        background-image: linear-gradient(
            rgba(0, 0, 0, 0.45),
            rgba(0, 0, 0, 0.45)
        ), url('@Url.Content("~/images/car-banner.webp")');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-align: center;
        margin-bottom: 45px;
    }

    .home-banner-content {
        max-width: 850px;
        padding: 40px 25px;
    }

    .home-banner-content h1 {
        font-size: 52px;
        font-weight: 700;
        margin-bottom: 20px;
        color: white;
    }

    .home-banner-content p {
        font-size: 20px;
        line-height: 1.6;
        margin-bottom: 30px;
        color: rgba(255, 255, 255, 0.92);
    }

    .home-banner .btn {
        border-radius: 4px;
        font-weight: 600;
        text-transform: none;
    }

    .home-title-section {
        margin-bottom: 35px;
    }

    .icon-block {
        padding: 20px 15px;
    }

    @@media only screen and (max-width: 768px) {
        .home-banner {
            min-height: 340px;
        }

        .home-banner-content h1 {
            font-size: 34px;
        }

        .home-banner-content p {
            font-size: 16px;
        }
    }
</style>

<div class="home-banner">
    <div class="home-banner-content">
        <h1>Automobile Service Center</h1>

        <p>
            Professional automobile service management system for customers,
            service engineers and administrators.
        </p>

        <a asp-controller="Home" asp-action="GetStarted" class="btn waves-effect waves-light teal">
            Get Started
            <i class="material-icons right">arrow_forward</i>
        </a>
    </div>
</div>

<div class="section no-pad-bot home-title-section">
    <div class="container center">
        <h1 class="header teal-text text-darken-2">Automobile Service Center</h1>
        <div class="row center">
            <h5 class="header col s12 light">
                Professional automobile service management system
            </h5>
        </div>
        <div class="row center">
            <a asp-controller="Home" asp-action="GetStarted" class="btn waves-effect waves-light">
                Get Started
            </a>
        </div>
    </div>
</div>

<div class="container">
    <div class="section">
        <div class="row">

            <div class="col s12 m4">
                <div class="icon-block center">
                    <h2 class="brown-text">
                        <i class="material-icons">group</i>
                    </h2>
                    <h5>Who we are</h5>
                    <p class="light">
                        We provide high-quality automobile services with a customer-first approach.
                    </p>
                </div>
            </div>

            <div class="col s12 m4">
                <div class="icon-block center">
                    <h2 class="brown-text">
                        <i class="material-icons">flash_on</i>
                    </h2>
                    <h5>Our Competency</h5>
                    <p class="light">
                        Our service engineers are trained to solve complex automobile service problems.
                    </p>
                </div>
            </div>

            <div class="col s12 m4">
                <div class="icon-block center">
                    <h2 class="brown-text">
                        <i class="material-icons">settings</i>
                    </h2>
                    <h5>Easy to work with</h5>
                    <p class="light">
                        We support customers with clear information, fast service, and continuous communication.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>