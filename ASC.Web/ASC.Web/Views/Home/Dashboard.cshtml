@{
    ViewData["Title"] = "Dashboard";
    Layout = "_SecureLayout";
}

<section class="asc-dashboard-hero">
    <h1 class="asc-page-title">Dashboard</h1>
    <p class="asc-page-subtitle">
        Welcome to Automobile Service Center. Use the menu to manage requests, notifications, promotions, and account settings.
    </p>
</section>

<section class="asc-card-grid">
    <div class="card teal lighten-1 asc-stat-card">
        <div class="card-content white-text">
            <div class="asc-stat-icon">
                <i class="material-icons">local_car_wash</i>
            </div>
            <span class="card-title">Service Requests</span>
            <p>Manage customer service requests and service workflows.</p>
        </div>
    </div>

    <div class="card orange lighten-1 asc-stat-card">
        <div class="card-content white-text">
            <div class="asc-stat-icon">
                <i class="material-icons">notifications</i>
            </div>
            <span class="card-title">Notifications</span>
            <p>View service notifications and customer communication updates.</p>
        </div>
    </div>

    <div class="card blue lighten-1 asc-stat-card">
        <div class="card-content white-text">
            <div class="asc-stat-icon">
                <i class="material-icons">sell</i>
            </div>
            <span class="card-title">Promotions</span>
            <p>Manage promotions, offers, and service campaigns.</p>
        </div>
    </div>
</section>
