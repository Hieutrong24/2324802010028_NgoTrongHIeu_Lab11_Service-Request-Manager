@model ProfileModel

@{
    ViewData["Title"] = "Profile";
    Layout = "_SecureLayout";
}

<div class="section">
    <h4 class="teal-text text-darken-2">Profile</h4>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="card-panel green lighten-4 green-text text-darken-4">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="row">
        <div class="col s12 m8 offset-m2">
            <div class="card z-depth-2">
                <div class="card-content">
                    <span class="card-title">Update Profile</span>

                    <form asp-area="Accounts"
                          asp-controller="Account"
                          asp-action="Profile"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input asp-for="Id" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="red-text"></div>

                        <div class="input-field">
                            <input asp-for="Email" readonly />
                            <label asp-for="Email" class="active"></label>
                        </div>

                        <div class="input-field">
                            <input asp-for="UserName" />
                            <label asp-for="UserName" class="active"></label>
                            <span asp-validation-for="UserName" class="red-text"></span>
                        </div>

                        <div class="center-align" style="margin-top: 25px;">
                            <button type="submit" class="btn waves-effect waves-light teal">
                                Save
                                <i class="material-icons right">save</i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}