@page
@model ExternalLoginModel

@{
    ViewData["Title"] = "Register";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="section">
        <div class="row">
            <div class="col s12 m8 offset-m2">
                <div class="card z-depth-2">
                    <div class="card-content">
                        <span class="card-title teal-text text-darken-2 center">
                            Register with Google
                        </span>

                        <p class="center grey-text text-darken-1">
                            You've successfully authenticated with
                            <strong>@Model.ProviderDisplayName</strong>.
                            Please confirm your email and click Register to finish logging in.
                        </p>

                        <form asp-page-handler="Confirmation"
                              asp-route-returnUrl="@Model.ReturnUrl"
                              method="post">

                            <div asp-validation-summary="ModelOnly" class="red-text"></div>

                            <div class="input-field">
                                <input asp-for="Input.Email" class="validate" readonly />
                                <label asp-for="Input.Email" class="active"></label>
                                <span asp-validation-for="Input.Email" class="red-text"></span>
                            </div>

                            <div class="center" style="margin-top: 30px;">
                                <button type="submit" class="btn waves-effect waves-light teal">
                                    Register
                                    <i class="material-icons right">send</i>
                                </button>

                                <a asp-page="./Login" class="btn waves-effect waves-light red lighten-1">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}