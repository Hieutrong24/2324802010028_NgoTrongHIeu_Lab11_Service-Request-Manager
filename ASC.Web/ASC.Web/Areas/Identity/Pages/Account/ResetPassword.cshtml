@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "Reset password";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="section">
        <div class="row">
            <div class="col s12 m8 offset-m2 l6 offset-l3">
                <div class="card z-depth-2">
                    <div class="card-content">
                        <span class="card-title teal-text text-darken-2 center">
                            Reset Password
                        </span>

                        <p class="center grey-text">
                            Enter your email and new password.
                        </p>

                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="red-text"></div>

                            <input asp-for="Input.Code" type="hidden" />

                            <div class="input-field">
                                <input asp-for="Input.Email"
                                       class="validate"
                                       autocomplete="username"
                                       placeholder="name@example.com" />
                                <label asp-for="Input.Email"></label>
                                <span asp-validation-for="Input.Email" class="red-text"></span>
                            </div>

                            <div class="input-field">
                                <input asp-for="Input.Password"
                                       class="validate"
                                       autocomplete="new-password"
                                       placeholder="Enter new password" />
                                <label asp-for="Input.Password"></label>
                                <span asp-validation-for="Input.Password" class="red-text"></span>
                            </div>

                            <div class="input-field">
                                <input asp-for="Input.ConfirmPassword"
                                       class="validate"
                                       autocomplete="new-password"
                                       placeholder="Confirm new password" />
                                <label asp-for="Input.ConfirmPassword"></label>
                                <span asp-validation-for="Input.ConfirmPassword" class="red-text"></span>
                            </div>

                            <div class="center" style="margin-top: 25px;">
                                <button type="submit" class="btn waves-effect waves-light teal">
                                    Reset Password
                                    <i class="material-icons right">lock_reset</i>
                                </button>
                            </div>

                            <div class="center" style="margin-top: 20px;">
                                <a asp-page="./Login">Back to Login</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}